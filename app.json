{
  "expo": {
    "name": "CanchaYa",
    "slug": "canchaya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "canchaya",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.canchaya.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CanchaYa necesita acceso a tu ubicaci\u00f3n para mostrarte canchas deportivas cercanas."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.canchaya.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "CanchaYa necesita acceso a tu ubicaci\u00f3n para mostrarte canchas deportivas cercanas."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6163b54f-1ef7-4d21-bde7-47e7c8070861"
      },
      "router": {}
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6163b54f-1ef7-4d21-bde7-47e7c8070861"
    },
    "owner": "leohr09"
  }
}